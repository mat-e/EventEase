@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center mt-4 mb-5">
    <h1 class="display-4">Welcome</h1>
    <h3>Event Easy: Book & Enjoy!</h3>
</div>

<!-- Quick Navigation Legend -->
<div class="legend-card">
    <h5 class="legend-title">Quick Navigation</h5>
    <div class="legend-grid">

        <a asp-controller="Home" asp-action="Index" class="legend-item">
            <div class="legend-icon">🏠</div>
            <div class="legend-info">
                <span class="legend-name">Home</span>
                <span class="legend-desc">Go to the main page</span>
            </div>
        </a>

        <a asp-controller="Venues" asp-action="Index" class="legend-item">
            <div class="legend-icon">🏟️</div>
            <div class="legend-info">
                <span class="legend-name">Venues</span>
                <span class="legend-desc">Browse & manage venues</span>
            </div>
        </a>

        <a asp-controller="Customers" asp-action="Index" class="legend-item">
            <div class="legend-icon">👥</div>
            <div class="legend-info">
                <span class="legend-name">Customers</span>
                <span class="legend-desc">View & manage customers</span>
            </div>
        </a>

        <a asp-controller="Events" asp-action="Index" class="legend-item">
            <div class="legend-icon">🎉</div>
            <div class="legend-info">
                <span class="legend-name">Events</span>
                <span class="legend-desc">Browse & create events</span>
            </div>
        </a>

        <a asp-controller="Bookings" asp-action="Index" class="legend-item">
            <div class="legend-icon">📋</div>
            <div class="legend-info">
                <span class="legend-name">Bookings</span>
                <span class="legend-desc">Manage all bookings</span>
            </div>
        </a>

    </div>
</div>
