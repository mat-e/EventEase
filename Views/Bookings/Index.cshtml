@model IEnumerable<EventEase.Models.Booking>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Bookings</h1>
    <a class="btn btn-success" asp-action="Create">New Booking</a>
</div>

<p class="table-caption-compact">List of bookings with venue and event.</p>

<div class="table-responsive-custom">
    <table class="table table-striped table-hover table-custom">
        <thead>
            <tr>
                <th>BookingId</th>
                <th>BookingDate</th>
                <th>Event</th>
                <th>Venue</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="5" class="table-empty">No bookings found.</td>
            </tr>
        }
        else
        {
            foreach (var item in Model)
            {
                <tr>
                    <td>@item.BookingId</td>
                    <td>@item.BookingDate.ToString("yyyy-MM-dd")</td>
                    <td>@item.Event?.EventName</td>
                    <td>@item.Venue?.VenueName</td>
                    <td class="text-end table-actions">
                        <a class="btn btn-sm btn-primary" asp-action="Edit" asp-route-id="@item.BookingId">Edit</a>
                        <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@item.BookingId">Delete</a>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>
