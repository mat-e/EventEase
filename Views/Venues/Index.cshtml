@model IEnumerable<EventEase.Models.Venue>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Venues</h1>
    <a class="btn btn-success" asp-action="Create">New Venue</a>
</div>

<p class="table-caption-compact">List of venues.</p>

<div class="table-responsive-custom">
    <table class="table table-striped table-hover table-custom">
        <thead>
            <tr>
                <th>VenueId</th>
                <th>VenueName</th>
                <th>Location</th>
                <th>Capacity</th>
                <th>Image</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="6" class="table-empty">No venues found.</td>
            </tr>
        }
        else
        {
            foreach (var item in Model)
            {
                <tr>
                    <td>@item.VenueId</td>
                    <td>@item.VenueName</td>
                    <td>@item.Location</td>
                    <td>@item.Capacity</td>
                    <td>
                        @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" alt="@item.VenueName" style="height:40px;object-fit:cover;border-radius:4px;" />
                        }
                    </td>
                    <td class="text-end table-actions">
                        <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@item.VenueId">Details</a>
                        <a class="btn btn-sm btn-primary" asp-action="Edit" asp-route-id="@item.VenueId">Edit</a>
                        <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@item.VenueId">Delete</a>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>
